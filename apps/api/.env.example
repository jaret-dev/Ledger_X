# apps/api — see BUILD_PLAN §11 for the authoritative list across phases.

# Core
NODE_ENV=development
PORT=3001

# CORS — comma-separated origins. localhost:5173 is Vite dev.
CORS_ORIGIN=http://localhost:5173

# Database (reused by @ledger/db's Prisma client)
DATABASE_URL="postgresql://ledger:ledger@localhost:5432/ledger?schema=public"

# Agent ingestion secret (shared with apps/agent; set in Phase 4)
# Generate once: `openssl rand -hex 32`
LEDGER_AGENT_KEY=replace-me-in-phase-4

# Clerk JWT verification (Phase 5+). Required in production. Optional in
# dev/test — when unset, clerkAuth falls back to the legacy x-household-id
# header so the test suite + local-dev workflows keep working.
# Get from clerk.com → app dashboard → API Keys. Format: sk_test_... / sk_live_...
CLERK_SECRET_KEY=

# Future phases — uncomment when they land
# ENCRYPTION_KEY=         # Phase 7 — openssl rand -hex 32
# PLAID_CLIENT_ID=        # Phase 7
# PLAID_SECRET=           # Phase 7
# PLAID_ENV=sandbox       # Phase 7
# PLAID_COUNTRY_CODES=CA  # Phase 7

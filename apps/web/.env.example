# apps/web — see BUILD_PLAN §11.
# In production on Vercel, set VITE_API_URL to the Railway API URL.
VITE_API_URL=http://localhost:3001

# Clerk publishable key (Phase 5+). Required in production; the app
# crashes on boot without it. Get from clerk.com → app dashboard → API Keys.
# Format: pk_test_... (dev) or pk_live_... (prod).
VITE_CLERK_PUBLISHABLE_KEY=
